// ==========================================
// KALMAN FILTER STRUCT & REGISTER CORES
// ==========================================
struct Kalman {
    float Q_angle = 0.001f;   // Process noise variance for the single accelerometer axis
    float Q_bias  = 0.003f;   // Process noise variance for the gyroscope bias drift
    float R_measure = 0.03f;  // Measurement noise variance from structural vibrations

    float angle = 0.0f; 
    float bias = 0.0f;  
    float P[2][2] = {{0, 0}, {0, 0}};

    float update(float newAngle, float newRate, float dt) {
        // Step 1: Predict (Time Update)
        float rate = newRate - bias;
        angle += dt * rate;

        P[0][0] += dt * (dt * P[1][1] - P[0][1] - P[1][0] + Q_angle);
        P[0][1] -= dt * P[1][1];
        P[1][0] -= dt * P[1][1];
        P[1][1] += Q_bias * dt;

        // Step 2: Update (Measurement Correction)
        float S = P[0][0] + R_measure;
        float K[2]; 
        K[0] = P[0][0] / S;
        K[1] = P[1][0] / S;

        float y = newAngle - angle;
        angle += K[0] * y;
        bias  += K[1] * y;

        float P00_temp = P[0][0];
        float P01_temp = P[0][1];

        P[0][0] -= K[0] * P00_temp;
        P[0][1] -= K[0] * P01_temp;
        P[1][0] -= K[1] * P00_temp;
        P[1][1] -= K[1] * P01_temp;

        return angle;
    };
};

Kalman kalmanRoll;  // מסנן קלמן עבור ציר ה-Roll (X)
Kalman kalmanPitch; // מסנן קלמן עבור ציר ה-Pitch (Y)

