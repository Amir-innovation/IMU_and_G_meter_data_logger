// ==========================================
// SETUP (BOOTTIME LOGIC)
// ==========================================
void setup() {
  #if ENABLE_DEBUG
    Serial.begin(115200);
  #endif
  
  DEBUG_PRINTLN("--- STARTING SYSTEM INITIALIZATION ---");
  
  pinMode(STATUS_LED, OUTPUT);
  digitalWrite(STATUS_LED, LOW); 

  // 1. Initialize MicroSD Card File System
  if (!SD.begin(SD_CS)) {
    while (1) { 
      digitalWrite(STATUS_LED, HIGH); delay(50);
      digitalWrite(STATUS_LED, LOW);  delay(50);
    }
  }

  // 2. Start I2C Bus and Boost Clock to Fast Mode (400kHz)
  Wire.begin(); 
  Wire.setClock(400000); 
  
  if (!kxAccel.begin()) {
    while (1) { 
      digitalWrite(STATUS_LED, HIGH); delay(100);
      digitalWrite(STATUS_LED, LOW);  delay(100);
    }
  }
  
  // Sample position quickly using narrow 8G window for accuracy
  kxAccel.enableAccel(false); 
  kxAccel.setRange(SFE_KX134_RANGE8G); 
  kxAccel.enableDataEngine();
  kxAccel.enableAccel(); 
  delay(30); 

  outputData bootCheck;
  kxAccel.getAccelData(&bootCheck);
  DEBUG_PRINTF("Boot orientation Z-reading: %.2f G\n", bootCheck.zData);

  if (bootCheck.zData < -0.5) { 
    recoveryMode = true;
    DEBUG_PRINTLN("Inverted boot detected. Web Portal & OTA requested.");
  }

  // 3. HARDWARE ACCELERATION & ODR BOOST CONFIGURATION
  kxAccel.enableAccel(false); 
  kxAccel.setRange(SFE_KX134_RANGE64G); 
  kxAccel.setOutputDataRate(11); // Force sensor core to refresh internally at 1600Hz
  kxAccel.enableDataEngine();
  kxAccel.enableAccel(); 

  // Wake up Gyroscope (MPU-9250) and clear sample dividers
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x6B); 
  Wire.write(0x00); 
  Wire.endTransmission();

  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x1B); 
  Wire.write(0x18); // Gyro Full Scale Range to ±2000 DPS
  Wire.endTransmission();

  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x1A); 
  Wire.write(0x00); // Set DLPF to max bandwidth (True 8kHz internal / 1kHz output)
  Wire.endTransmission();

  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x19); 
  Wire.write(0x00); // Sample Rate Divider = 0
  Wire.endTransmission();

  // 4. ROUTING EXECUTION
  if (recoveryMode) {
    startWiFiPortal();
    return; 
  }

  // --- AUTONOMOUS FLIGHT ROADWAY (If Upright) ---
  int fileIndex = 0;
  while (true) {
    snprintf(filename, sizeof(filename), "/log_%03d.csv", fileIndex);
    if (!SD.exists(filename)) {
      break; 
    }
    fileIndex++; 
  }

  logFile = SD.open(filename, FILE_WRITE);
  if (!logFile) {
    while (1);
  }

  // עדכון כותרות הקובץ ל-Roll, Pitch, Yaw
  logFile.println("Timestamp_ms,AccelX_G,AccelY_G,AccelZ_G,GyroX_dps,GyroY_dps,GyroZ_dps,Velocity_m_s,Roll,Pitch,Yaw");
  logFile.flush(); 
  
  logStartMillis = millis();
  lastSampleMicros = micros();
  lastVelocityMicros = micros();
  lastFlushMillis = millis();
  
  velocity_m_s = 0.0; 
  roll = 0.0;
  pitch = 0.0;
  yaw = 0.0;
  kalmanRoll.angle = 0.0;
  kalmanPitch.angle = 0.0;

  loggingActive = true;
  DEBUG_PRINTLN("Autonomous recording pipeline active.");
  digitalWrite(STATUS_LED, HIGH); 
}

// ==========================================
// PROCESSING CORE
// ==========================================
void loop() {
  if (recoveryMode) {
    server.handleClient();
    ArduinoOTA.handle(); // מאזין לבקשות צריבה אלחוטיות באוויר (רק במצב התאוששות)
    
    if (loggingActive) {
      runFlightLogging();
    } else {
      digitalWrite(STATUS_LED, (millis() % 2000 < 1000) ? HIGH : LOW);
    }
  } else {
    runFlightLogging();
  }
}

// ==========================================
// HIGH-SPEED DATA LOGGING ENGINE
// ==========================================
void runFlightLogging() {
  if (!loggingActive) return;

  unsigned long currentMicros = micros();

  // Hard Time-Slice Interlock: Maintain 1000Hz synchronization grid
  if (currentMicros - lastSampleMicros < 1000) {
    return; 
  }
  lastSampleMicros += 1000; 

  unsigned long currentMillis = millis();

  // 2. Collect High-G Telemetry Profiles
  outputData accelData;
  kxAccel.getAccelData(&accelData);
  float ax = accelData.xData;
  float ay = accelData.yData;
  float az = accelData.zData;

  float totalG = sqrt(ax * ax + ay * ay + az * az);

  // 3. REAL-TIME MATH INTEGERS & KALMAN ATTITUDE FILTER
  float dt = (currentMicros - lastVelocityMicros) / 1000000.0; 
  lastVelocityMicros = currentMicros;

  float netG = totalG - 1.0; 
  if (totalG > 0.96 && totalG < 1.04) {
    netG = 0.0;
  }

  float accel_m_s2 = netG * 9.80665;
  velocity_m_s += accel_m_s2 * dt;
  if (velocity_m_s < 0.0) velocity_m_s = 0.0; 

  // Capture Rotational Rates from MPU Gyroscope
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x43); 
  Wire.endTransmission(false);
  Wire.requestFrom(MPU_ADDR, 6, true); 

  int16_t rawGyroX = (Wire.read() << 8) | Wire.read();
  int16_t rawGyroY = (Wire.read() << 8) | Wire.read();
  int16_t rawGyroZ = (Wire.read() << 8) | Wire.read();

  float gx = rawGyroX / 16.4; // ג'יירו X (קצב גלגול - Roll Rate)
  float gy = rawGyroY / 16.4; // ג'יירו Y (קצב עלרוד - Pitch Rate)
  float gz = rawGyroZ / 16.4; // ג'יירו Z (קצב סבסוב - Yaw Rate)

  // חישוב זוויות נטייה גולמיות ממד התאוצה (טריגונומטריה מותאמת)
  float accelRoll = atan2(ay, az) * 57.29578; 
  float accelPitch = atan2(-ax, sqrt(ay * ay + az * az)) * 57.29578;

  // תיקון קפיצת 180 מעלות (Angle Unwrapping) למניעת השתוללות פילטר קלמן בסיבוב ימני
  if ((accelRoll - kalmanRoll.angle) > 180.0) {
      accelRoll -= 360.0;
  } else if ((accelRoll - kalmanRoll.angle) < -180.0) {
      accelRoll += 360.0;
  }

  // מנגנון הגנה דינמי (Rocket Flight Interlock)
  if (totalG < 0.75 || totalG > 1.25) {
      // שלב דינמי: אינטגרציה ישירה של קצבי הסיבוב
      roll  += gx * dt;
      pitch += gy * dt;
      
      // סינכרון מצב פנימי של פילטר קלמן
      kalmanRoll.angle = roll;
      kalmanPitch.angle = pitch;
  } else {
      // שלב יציב: עדכון קלמן משולב עם מד התאוצה למניעת סחיפה
      roll  = kalmanRoll.update(accelRoll, gx, dt);
      pitch = kalmanPitch.update(accelPitch, gy, dt);
  }

  // ציר ה-Yaw (סבסוב) תמיד מבוסס אינטגרציית ג'יירו ישירה (ציר Z)
  yaw += gz * dt;

  // 4. Absolute Crash/Structural Escape Logic (60G Limit)
  if (totalG >= 60.0) {
    logFile.printf("%lu,%.2f,%.2f,%.2f,0.0,0.0,0.0,%.2f,%.2f,%.2f,%.2f\n", 
                   currentMillis - logStartMillis, ax, ay, az, velocity_m_s, roll, pitch, yaw);
    logFile.println("--- 60G HIGH THRESHOLD BROKEN. LOG SEALED ---");
    logFile.close(); 
    digitalWrite(STATUS_LED, LOW); 
    loggingActive = false;
    return;
  }

  // 6. Commit Row Array to SD Buffer
  logFile.print(currentMillis - logStartMillis); logFile.print(",");
  logFile.print(ax, 3);                          logFile.print(",");
  logFile.print(ay, 3);                          logFile.print(",");
  logFile.print(az, 3);                          logFile.print(",");
  logFile.print(gx, 2);                          logFile.print(",");
  logFile.print(gy, 2);                          logFile.print(",");
  logFile.print(gz, 2);                          logFile.print(",");
  logFile.print(velocity_m_s, 2);                logFile.print(",");
  logFile.print(roll, 2);                        logFile.print(",");
  logFile.print(pitch, 2);                       logFile.print(",");
  logFile.println(yaw, 2);              

  // 7. Batched Flush Strategy (Fires every 50ms)
  if (currentMillis - lastFlushMillis >= 50) {
    logFile.flush();
    lastFlushMillis = currentMillis;
  }

  // 8. Graph Engine Data Relay - מציג רק Roll, Pitch, Yaw
  PLOT_DATA(ax, ay, az, gx, gy, gz, velocity_m_s, roll, pitch, yaw, 1);

  // 9. Flight Recording Visual Signal
  static unsigned long lastBlink = 0;
  static bool ledState = LOW;
  if (currentMillis - lastBlink >= 100) {
    ledState = !ledState;
    digitalWrite(STATUS_LED, ledState);
    lastBlink = currentMillis;
  }
}

// ==========================================
// WIRELESS RECOVERY WEB PORTAL & OTA LAYER
// ==========================================
void startWiFiPortal() {
  WiFi.softAP(ap_ssid, ap_password);
  
  // הגדרות אתחול שירות ה-OTA
  ArduinoOTA.setHostname("Xiao-Flight-Computer"); 
  ArduinoOTA.setPassword("admin123");           
  
  ArduinoOTA.onStart([]() { DEBUG_PRINTLN("OTA Update Started..."); });
  ArduinoOTA.onEnd([]() { DEBUG_PRINTLN("\nOTA Update Finished!"); });
  ArduinoOTA.onProgress([](unsigned int progress, unsigned int total) {
    DEBUG_PRINTF("Progress: %u%%\r", (progress / (total / 100)));
  });
  ArduinoOTA.onError([](ota_error_t error) { DEBUG_PRINTF("Error[%u]\n", error); });
  
  ArduinoOTA.begin(); 

  server.on("/", handleRoot);
  server.on("/download", handleDownload);
  server.on("/delete", handleDelete);
  server.on("/delete_all", handleDeleteAll); 
  server.on("/start_log", handleStartLog);
  server.on("/stop_log", handleStopLog);
  
  server.begin();
}

