void handleStartLog() {
  if (!loggingActive) {
    int fileIndex = 0;
    while (true) {
      snprintf(filename, sizeof(filename), "/log_%03d.csv", fileIndex);
      if (!SD.exists(filename)) { break; }
      fileIndex++; 
    }
    
    logFile = SD.open(filename, FILE_WRITE);
    if (logFile) {
      logFile.println("Timestamp_ms,AccelX_G,AccelY_G,AccelZ_G,GyroX_dps,GyroY_dps,GyroZ_dps,Velocity_m_s,Roll,Pitch,Yaw");
      logFile.flush();
      
      velocity_m_s = 0.0; roll = 0.0; pitch = 0.0; yaw = 0.0;
      kalmanRoll.angle = 0.0; kalmanPitch.angle = 0.0;

      logStartMillis = millis(); 
      lastSampleMicros = micros();
      lastVelocityMicros = micros(); 
      lastFlushMillis = millis();
      loggingActive = true;
    }
  }
  server.sendHeader("Location", "/");
  server.send(303);
}

void handleStopLog() {
  if (loggingActive) {
    logFile.println("--- RECORDING TERMINATED MANUALLY VIA WEB RUNTIME ---");
    logFile.close();
    loggingActive = false;
    digitalWrite(STATUS_LED, LOW);
  }
  server.sendHeader("Location", "/");
  server.send(303);
}

void handleDownload() {
  if (!server.hasArg("file")) { server.send(400, "text/plain", "Missing parameter"); return; }
  String path = "/" + server.arg("file");
  if (!SD.exists(path)) { server.send(404, "text/plain", "File Missing"); return; }
  
  File file = SD.open(path, FILE_READ);
  server.streamFile(file, "text/csv");
  file.close();
}

void handleDelete() {
  if (!server.hasArg("file")) { server.send(400, "text/plain", "Missing parameter"); return; }
  String path = "/" + server.arg("file");
  if (SD.exists(path)) {
    SD.remove(path);
  }
  server.sendHeader("Location", "/");
  server.send(303);
}

void handleDeleteAll() {
  if (loggingActive) { 
    server.send(400, "text/plain", "Cannot delete logs while recording is active!"); 
    return; 
  }
  
  File root = SD.open("/");
  File file = root.openNextFile();
  
  while (file) {
    if (!file.isDirectory()) {
      String path = "/" + String(file.name());
      file.close(); 
      SD.remove(path);
    } else {
      file.close();
    }
    file = root.openNextFile();
  }
  root.close();
  
  DEBUG_PRINTLN("All storage log files cleared manually via web dashboard.");
  server.sendHeader("Location", "/");
  server.send(303);
}
